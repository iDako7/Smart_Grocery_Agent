{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/merge_safety_check.sh"
          }
        ]
      },
      {
        "matcher": "create_pull_request|update_pull_request",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/ci-before-pr.sh",
            "timeout": 120,
            "statusMessage": "Running local CI checks before PR…"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/ci-before-pr.sh",
            "timeout": 120,
            "statusMessage": "Running local CI checks before PR…"
          }
        ]
      }
    ]
  }
}
