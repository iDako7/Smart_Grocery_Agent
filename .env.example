# OpenRouter (LLM provider)
OPENROUTER_API_KEY=sk-or-v1-your-key-here
SGA_MODEL=openai/gpt-5.4-mini
JUDGE_MODEL_A=anthropic/claude-opus-4-6
JUDGE_MODEL_B=openai/gpt-5.4

# PostgreSQL
POSTGRES_DB=sga
POSTGRES_USER=sga
POSTGRES_PASSWORD=sga_dev
# PostgreSQL connection URL
# - Local uvicorn (host):     postgresql+asyncpg://sga:sga_dev@localhost:5432/sga
# - Docker compose (service): postgresql+asyncpg://sga:sga_dev@db:5432/sga
DATABASE_URL=postgresql+asyncpg://sga:sga_dev@db:5432/sga

# Redis (tool cache) — docker compose overrides this to the `redis` service hostname (same pattern as DATABASE_URL above)
REDIS_URL=redis://localhost:6379/0

# JWT — the app refuses to start with the placeholder value below
JWT_SECRET=change-me-in-production
