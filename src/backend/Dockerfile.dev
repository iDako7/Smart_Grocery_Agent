FROM python:3.13-slim

# Install uv
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /usr/local/bin/

WORKDIR /app

# Install dependencies (context is repo root; files live in src/backend/)
COPY src/backend/pyproject.toml src/backend/uv.lock ./
RUN uv sync --frozen

# /app is the repo root at runtime; src.backend.*, src.ai.*, contracts.* all resolve from here
ENV PYTHONPATH="/app:${PYTHONPATH}"

EXPOSE 8000

CMD ["sh", "-c", "uv run alembic -c src/backend/alembic.ini upgrade head && uv run uvicorn src.backend.main:app --reload --host 0.0.0.0 --port 8000"]
